# SASTBot environment variables
#
# Copy this file to .env and customize. .env is gitignored.
# For production, set these in your deployment platform (e.g., Dokploy env vars),
# NEVER commit a real .env file.

# =============================================================================
# Required
# =============================================================================

# MASTER_KEY — 32-byte key (base64-encoded) used to AES-GCM encrypt credentials
# in Postgres. The backend refuses to start if this is missing, wrong length,
# or cannot decrypt the canary row.
#
# Generate a fresh one with:
#   python3 -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
#
# The example below is a PLACEHOLDER. Regenerate for any real deployment.
MASTER_KEY=NEEv6vwFIzi5U1VgMDWmCQB8AXOtjj9esL1E7BoiLf0=

# =============================================================================
# Database (compose sets sensible defaults)
# =============================================================================

POSTGRES_USER=sastbot
POSTGRES_PASSWORD=sastbot
POSTGRES_DB=sastbot
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Async SQLAlchemy URL. The backend composes this from the above, but you can
# override it for a non-compose setup.
# DATABASE_URL=postgresql+asyncpg://sastbot:sastbot@postgres:5432/sastbot

# =============================================================================
# Redis (compose sets this automatically)
# =============================================================================

REDIS_URL=redis://redis:6379/0

# =============================================================================
# Web / auth
# =============================================================================

# Origin allowed by CORS (React dev server). Production should use your deploy URL.
APP_ORIGIN=http://localhost:5173

# When true, session cookies are marked Secure (HTTPS only). Keep false locally,
# true in production.
SESSION_COOKIE_SECURE=false

# Optional: override the bootstrap admin email. If unset, defaults to
# admin@sastbot.local and a random password is printed to backend logs on first boot.
# BOOTSTRAP_ADMIN_EMAIL=admin@sastbot.local

# =============================================================================
# Logging / misc
# =============================================================================

LOG_LEVEL=info
