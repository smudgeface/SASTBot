# --- Required ---

# 32-byte AES-256-GCM key, base64-encoded.
# Generate once: `node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"`
# The backend refuses to start if this is missing or does not match the stored
# encryption canary row in the database.
MASTER_KEY=

# Prisma Postgres connection string.
DATABASE_URL=postgresql://sastbot:sastbot@postgres:5432/sastbot

# Redis connection string (used by BullMQ for scan jobs).
REDIS_URL=redis://redis:6379/0

# CORS origin for the frontend SPA.
APP_ORIGIN=http://localhost:5173

# Cookie Secure flag — set to "true" behind HTTPS in prod; "false" for local dev.
SESSION_COOKIE_SECURE=false

# --- Optional ---

# Lazy-bootstrap admin email (password is randomly generated + printed to logs).
BOOTSTRAP_ADMIN_EMAIL=admin@sastbot.local

# pino log level.
LOG_LEVEL=info

# Listen port.
PORT=8000
