// SASTBot Prisma schema.
// Models mirror the Python/SQLAlchemy M1 design so the API contract stays
// identical for the existing React frontend.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Org {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  users       User[]
  repos       Repo[]
  credentials Credential[]
  scanRuns    ScanRun[]
  scanScopes  ScanScope[]
  appSettings AppSettings[]

  @@map("orgs")
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  orgId        String?   @map("org_id") @db.Uuid
  email        String    @unique
  passwordHash String    @map("password_hash")
  role         String // "admin" | "user"
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  lastLoginAt  DateTime? @map("last_login_at") @db.Timestamptz(6)

  org      Org?      @relation(fields: [orgId], references: [id], onDelete: SetNull)
  sessions Session[]

  @@map("users")
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  userAgent String?  @map("user_agent")
  ipAddress String?  @map("ip_address")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Credential {
  id         String    @id @default(uuid()) @db.Uuid
  orgId      String?   @map("org_id") @db.Uuid
  kind       String
  name       String
  ciphertext Bytes
  nonce      Bytes
  tag        Bytes // GCM auth tag (stored separately; see security/crypto.ts)
  keyVersion Int       @default(1) @map("key_version")
  // Kind-specific non-secret fields: username for https_basic,
  // optional known_hosts for ssh_key, etc. Secrets (passwords,
  // passphrases, private keys) are NEVER stored here — they live
  // encrypted in `ciphertext`. See services/credentialService.ts.
  metadata   Json?
  expiresAt  DateTime? @map("expires_at") @db.Timestamptz(6)
  createdBy  String?   @map("created_by") @db.Uuid
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  org          Org?          @relation(fields: [orgId], references: [id], onDelete: SetNull)
  reposUsing   Repo[]        @relation("RepoCredential")
  jiraSettings AppSettings[] @relation("JiraCredential")
  llmSettings  AppSettings[] @relation("LlmCredential")

  @@map("credentials")
}

model ScanScope {
  id          String   @id @default(uuid()) @db.Uuid
  orgId       String?  @map("org_id") @db.Uuid
  repoId      String   @map("repo_id") @db.Uuid
  // Relative path within the repo to scan (e.g. "/" or "services/api").
  // Combined with the repo URL this forms the canonical unit of analysis.
  path        String   @default("/")
  displayName String?  @map("display_name")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  org      Org?      @relation(fields: [orgId], references: [id], onDelete: SetNull)
  repo     Repo      @relation(fields: [repoId], references: [id], onDelete: Cascade)
  scanRuns ScanRun[]

  @@unique([repoId, path], name: "uq_scan_scopes_repo_path")
  @@map("scan_scopes")
}

model Repo {
  id            String    @id @default(uuid()) @db.Uuid
  orgId         String?   @map("org_id") @db.Uuid
  // When true, the worker keeps the on-disk clone between scans and
  // updates via `git fetch` + `git reset` on subsequent runs instead of
  // re-cloning. Faster, at the cost of disk space on the scanning host.
  retainClone   Boolean   @default(false) @map("retain_clone")
  // Set by the worker whenever it lands a clone/fetch on disk. Null when
  // no cached clone exists — used by the UI to enable/disable "Purge cache".
  lastClonedAt  DateTime? @map("last_cloned_at") @db.Timestamptz(6)
  name          String
  url           String
  protocol      String // "ssh" | "https"
  credentialId  String?  @map("credential_id") @db.Uuid
  defaultBranch String   @default("main") @map("default_branch")
  scanPaths     Json     @default("[\"/\"]") @map("scan_paths")
  analysisTypes Json     @default("[\"sca\"]") @map("analysis_types")
  scheduleCron  String?  @map("schedule_cron")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  org        Org?        @relation(fields: [orgId], references: [id], onDelete: SetNull)
  credential Credential? @relation("RepoCredential", fields: [credentialId], references: [id], onDelete: SetNull)
  scanRuns   ScanRun[]
  scopes     ScanScope[]

  @@unique([orgId, url], name: "uq_repos_org_url")
  @@map("repos")
}

model AppSettings {
  id               String   @id @default(uuid()) @db.Uuid
  orgId            String?  @unique @map("org_id") @db.Uuid
  jiraBaseUrl      String?  @map("jira_base_url")
  jiraCredentialId String?  @map("jira_credential_id") @db.Uuid
  llmBaseUrl       String?  @map("llm_base_url")
  llmApiFormat     String?  @map("llm_api_format")
  llmModel         String?  @map("llm_model")
  llmCredentialId  String?  @map("llm_credential_id") @db.Uuid
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  org            Org?        @relation(fields: [orgId], references: [id], onDelete: SetNull)
  jiraCredential Credential? @relation("JiraCredential", fields: [jiraCredentialId], references: [id], onDelete: SetNull)
  llmCredential  Credential? @relation("LlmCredential", fields: [llmCredentialId], references: [id], onDelete: SetNull)

  @@map("app_settings")
}

model ScanRun {
  id                String    @id @default(uuid()) @db.Uuid
  orgId             String?   @map("org_id") @db.Uuid
  repoId            String    @map("repo_id") @db.Uuid
  // Scope is the canonical unit — (repo, path). repoId is kept as a
  // denorm for cheap filtering without a join.
  scopeId           String    @map("scope_id") @db.Uuid
  status            String // "pending" | "running" | "success" | "failed"
  triggeredBy       String    @map("triggered_by") // "user" | "api" | "schedule"
  triggeredByUserId String?   @map("triggered_by_user_id") @db.Uuid
  startedAt         DateTime? @map("started_at") @db.Timestamptz(6)
  finishedAt        DateTime? @map("finished_at") @db.Timestamptz(6)
  error             String?
  // SCA summary counters — written by the worker after OSV lookup.
  componentCount    Int       @default(0) @map("component_count")
  criticalCount     Int       @default(0) @map("critical_count")
  highCount         Int       @default(0) @map("high_count")
  mediumCount       Int       @default(0) @map("medium_count")
  lowCount          Int       @default(0) @map("low_count")
  // Raw CycloneDX 1.7 SBOM produced by cdxgen; stored as JSONB for the
  // /scans/:id/sbom download endpoint. Null until the worker writes it.
  sbomJson          Json?     @map("sbom_json")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  org        Org?           @relation(fields: [orgId], references: [id], onDelete: SetNull)
  repo       Repo           @relation(fields: [repoId], references: [id], onDelete: Cascade)
  scope      ScanScope      @relation(fields: [scopeId], references: [id], onDelete: Cascade)
  components SbomComponent[]
  findings   ScanFinding[]

  @@map("scan_runs")
}

model SbomComponent {
  id            String   @id @default(uuid()) @db.Uuid
  scanRunId     String   @map("scan_run_id") @db.Uuid
  name          String
  version       String?
  purl          String
  ecosystem     String?
  licenses      String[]
  componentType String   @default("library") @map("component_type")

  scanRun  ScanRun       @relation(fields: [scanRunId], references: [id], onDelete: Cascade)
  findings ScanFinding[]

  @@index([scanRunId])
  @@map("sbom_components")
}

model ScanFinding {
  id                String   @id @default(uuid()) @db.Uuid
  scanRunId         String   @map("scan_run_id") @db.Uuid
  componentId       String   @map("component_id") @db.Uuid
  osvId             String   @map("osv_id")
  cveId             String?  @map("cve_id")
  severity          String   @default("unknown")
  cvssScore         Float?   @map("cvss_score")
  cvssVector        String?  @map("cvss_vector")
  summary           String?
  aliases           String[]
  activelyExploited Boolean  @default(false) @map("actively_exploited")
  detailJson        Json?    @map("detail_json")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  scanRun   ScanRun       @relation(fields: [scanRunId], references: [id], onDelete: Cascade)
  component SbomComponent @relation(fields: [componentId], references: [id], onDelete: Cascade)

  @@index([scanRunId])
  @@map("scan_findings")
}

model Canary {
  id         String @id @default(uuid()) @db.Uuid
  ciphertext Bytes
  nonce      Bytes
  tag        Bytes
  keyVersion Int    @default(1) @map("key_version")

  @@map("encryption_canary")
}
